# Your-eyes-visioncare-dev-env — mẫu biến môi trường local
# Copy thành .env. KHÔNG commit .env (PROJECT_ARCHITECTURE.md §14.2).
# TẤT CẢ giá trị ở đây là DEV ONLY — không dùng cho production.

# --- Port ---
HOST_PORT=
DATABASE_PORT=
REDIS_PORT=

# --- Kết nối ---
DATABASE_URL=
REDIS_URL=
MOBILE_API_BASE_URL=
GLASSES_API_BASE_URL=

# --- Thiết bị dev ---
DEVICE_SERIAL=
# DEV ONLY
DEVICE_SECRET_DEV_ONLY=

# --- Provider: mặc định mock (N9 — test không cần provider trả phí) ---
OCR_PROVIDER_MODE=mock
VLM_PROVIDER_MODE=mock

# --- Runtime ---
LOG_LEVEL=
